    "gameScript": {
        "Intro_Start": [
            {
                "text": "{setState:scenePrefix,Intro}{playVideo:intro}"
            },
            {
                "text": "{bg:JoyPolis}{showTextbox}{center}{color:lime}{blip:3}17 de septiembre, 10:34 p. m.{nl}Joypolis"
            },
            {
                "name": "Phoenix",
                "text": "{blip:1}{color:lightblue}(Mi nombre es Phoenix Wright.)"
            },
            {
                "name": "Phoenix",
                "text": "{color:lightblue}(Soy abogado defensor en el Bufete Wright & Co.)"
            },
            {
                "name": "Phoenix",
                "text": "{color:lightblue}(Recibí una solicitud de Maggey Byrde,{nl}{p:300}sospechosa de asesinato...)"
            },
            {
                "name": "Phoenix",
                "text": "{color:lightblue}(Y vine aquí, a Joypolis.)"
            },
            {
                "name": "Phoenix",
                "text": "{color:lightblue}(No creo que Maggey sea capaz de cometer un asesinato.)"
            },
            {
                "name": "Phoenix",
                "text": "{color:lightblue}(Tengo que encontrar la verdad y limpiar su nombre, pase lo que pase.)"
            },
            {
                "name": "Phoenix",
                "text": "{color:lightblue}(Para lograrlo,{nl}no puedo pasar por alto ni el más mínimo detalle.)"
            },
            {
                "name": "Phoenix",
                "text": "{color:lightblue}(Anotaré toda la {color:red}Información{color:lightblue}{nl}que encuentre en el {color:red}acta del juicio{color:lightblue}.)"
            },
            {
                "name": "Gumshoe",
                "text": "{color:white}{blip:1}{sprite:Gumshoe[\"Sad\"]}{hideCharacter}{hideTextbox}{fadeInCharacter:300}{p:200}{showTextbox}{startBGM:investigation,true}*suspiro*{p:200}..."
            },
            {
                "name": "Edgeworth",
                "text": "{fadeOutCharacter:300}{sprite:Edgeworth[\"Normal\"]}{hideCharacter}{fadeInCharacter:300}Detective Gumshoe, póngame al día con el caso de inmediato."
            },
            {
                "name": "Phoenix",
                "text": "{color:lightblue}{fadeOutBg}(Este es Miles Edgeworth.{nl}Un fiscal de la oficina del fiscal del distrito.)"
            },
            {
                "name": "Gumshoe",
                "text": "{fadeInBg}{fadeOutCharacter:300}{hideTextbox}{sprite:Gumshoe[\"ScratchingHead2\"]}{hideCharacter}{fadeInCharacter}{p:200}{sprite:Gumshoe[\"ScratchingHead\"]}{sprite:Gumshoe[\"Normal\"]}{showTextbox}{color:white}S-Sí, señor..."
            },
            {
                "name": "Phoenix",
                "text": "{color:lightblue}{fadeOutBg}(Y este es el detective Dick Gumshoe.{nl}Un detective de la comisaría local.)"
            },
            {
                "name": "Gumshoe",
                "text": "{color:white}{fadeInBg}{sprite:Gumshoe[\"Thinking\"]}La víctima es Kurumi Nakaki."
            },
            {
                "name": "Gumshoe",
                "text": "Trabajaba aquí en Joypolis como especialista en el espectáculo del Samurái de Acero, señor."
            },
            {
                "name": "Gumshoe",
                "text": "El cuerpo fue descubierto a las 10:05 p. m."
            },
            {
                "name": "Gumshoe",
                "text": "La hora estimada de la muerte es entre las 9:30 p. m. y las 10:30 p. m."
            },
            {
                "name": "Edgeworth",
                "text": "{fadeOutCharacter:300}{sprite:Edgeworth[\"Normal\"]}{hideCharacter}{fadeInCharacter:300}Y...{p:500} la sospechosa es..."
            },
            {
                "name": "Gumshoe",
                "text": "{fadeOutCharacter:300}{hideTextbox}{sprite:Gumshoe[\"ScratchingHead2\"]}{hideCharacter}{fadeInCharacter}{p:200}{sprite:Gumshoe[\"ScratchingHead\"]}{showTextbox}{sprite:Gumshoe[\"Sad\"]}... Maggey Byrde,{p:300} que trabajaba aquí a tiempo parcial como guardia de seguridad,{p:200} señor..."
            },
            {
                "name": "Phoenix",
                "text": "{fadeOutBg}{fadeOutCharacter:300}{sprite:Maggey[\"Officer\"]}{hideCharacter}{fadeInCharacter:300}{p:200}{sprite:Maggey[\"Salute_Officer\"]}{sprite:Maggey[\"Officer\"]}{color:lightblue}(Maggey era policía antes, y fue subordinada del detective Gumshoe.)"
            },
            {
                "name": "Phoenix",
                "text": "{color:lightblue}(El detective Gumshoe siempre cuidó de ella.{nl}Esto debe de estar siendo muy duro para él.)"
            },
            {
                "name": "Gumshoe",
                "text": "{fadeOutCharacter:300}{p:10}{sprite:Gumshoe[\"Sad\"]}{hideCharacter}{fadeInBg}{fadeInCharacter:300}{color:white}Parece que Maggey empujó a la víctima desde la{nl}4.ª planta del salón de actos..."
            },
            {
                "name": "Edgeworth",
                "text": "{fadeOutCharacter:300}{sprite:Edgeworth[\"Normal\"]}{hideCharacter}{fadeInCharacter:300}¿Y quién fue la persona que encontró el cuerpo?"
            },
            {
                "name": "Gumshoe",
                "text": "{fadeOutCharacter:300}{sprite:Gumshoe[\"Sad\"]}{hideCharacter}{fadeInCharacter:300}{sprite:Gumshoe[\"Normal\"]}El gerente del salón de actos de este parque,{nl}Frank Shawit, señor."
            },
            {
                "name": "Edgeworth",
                "text": "{fadeOutCharacter:300}{sprite:Edgeworth[\"Normal\"]}{hideCharacter}{fadeInCharacter:300}{sprite:Edgeworth[\"Smug\"]}Entiendo. Es un caso de lo más simple."
            },
            {
                "name": "Edgeworth",
                "text": "{sprite:Edgeworth[\"Angry\"]}Porque ya tenemos pruebas definitivas de la culpabilidad de la acusada."
            },
            {
                "name": "Phoenix",
                "text": "{flash}{playSound:damage}¡¿Qué!?"
            },
            {
                "name": "Phoenix",
                "text": "{color:lightblue}(No, no puedo dejar que eso me afecte.{nl}{p:300}No importa qué pruebas tengan,{p:200} no puedo perder.)"
            },
            {
                "name": "Phoenix",
                "text": "{color:lightblue}(Tengo que descubrir la verdad cueste lo que cueste{nl}{p:300}y demostrar la inocencia de Maggey.)"
            },
            {
                "text": "{setState:intro_done,true}{hideTextbox}{stopBGM:true}{p:500}{hideCharacter}{fadeOutFg}{fadeBg:phoenixMove}{playSound:jingle}{sectionEnd}{skip:0}"
            }
        ],
        "Intro_Examine_Default": [
            {
                "name": "Phoenix",
                "text": "{blip:1}No hay nada interesante aquí."
            }
        ],
        "Intro_evidence_default": [
            {
                "text": "{skip:0}{sectionEnd}"
            }
        ]
    }
}