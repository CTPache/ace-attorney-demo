    "crossExaminations": {
        "Gumshoe_Testimony": {
            "witnessName": "Gumshoe",
            "failSequence": "CE_Fail",
            "statements": {
                "0": {
                    "text": "{showLifeBar}{courtView:witness}{blip:1,true}{courtSprite:witness[\"Normal\"]}The defendant was found at the scene with a smoking gun, pal!",
                    "press": "Press_Statement_1"
                },
                "1": {
                    "text": "{showLifeBar}{courtView:witness}{blip:1,true}{courtSprite:witness[\"Confident\"]}I saw him standin' there with my own eyes!",
                    "press": "Press_Statement_2"
                },
                "1a": {
                    "text": "{showLifeBar}{courtView:witness}{blip:1,true}{courtSprite:witness[\"Normal\"]}I even saw the defendant's red tie with my own eyes!",
                    "press": "Press_Red_Tie_Detail"
                },
                "2": {
                    "text": "{showLifeBar}{courtView:witness}{blip:1,true}{courtSprite:witness[\"Confident\"]}And he was definitely smoking that expensive cigar we found!",
                    "press": "Press_Statement_3",
                    "present": {
                        "Cigar": "CE_Victory"
                    }
                },
                "hints": {
                    "text": "{jump:CE_Hints}"
                }
            },
            "initialStatements": [
                "0",
                "1",
                "2",
                "hints"
            ]
        }
    },
