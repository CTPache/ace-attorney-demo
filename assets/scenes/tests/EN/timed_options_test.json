    "gameScript": {
        "Intro": [
            {
                "text": "{bg:Lobby}{showTextbox}{hideCharacter}{center}{color:lime}{blip:3}Timed Options Test{color:white}"
            },
            {
                "name": "Phoenix",
                "text": "{startBGM:lobby,false}{sprite:Phoenix[\"Thinking\"]}{fadeInCharacter}{blip:1}This scene is a simple test for the new timed option field."
            },
            {
                "name": "Phoenix",
                "text": "First, a timed choice will appear with a green bar at the bottom."
            },
            {
                "text": "{jump:Timed_Question}{sectionEnd}"
            }
        ],
        "Timed_Question": [
            {
                "text": "{option:TimedChoice}{sectionEnd}"
            }
        ],
        "Timed_Correct": [
            {
                "name": "Phoenix",
                "text": "{showTextbox}{sprite:Phoenix[\"Confident\"]}{blip:1}Nice. You picked an answer before the timer expired."
            },
            {
                "text": "{jump:Untimed_Question}{sectionEnd}"
            }
        ],
        "Timed_Wrong": [
            {
                "name": "Phoenix",
                "text": "{showTextbox}{sprite:Phoenix[\"Sweating\"]}{blip:1}That was the wrong answer, but it still proves manual selection works."
            },
            {
                "text": "{jump:Untimed_Question}{sectionEnd}"
            }
        ],
        "Timed_Timeout": [
            {
                "name": "Maya",
                "text": "{showTextbox}{sprite:Maya[\"Normal\"]}{fadeInCharacter}{blip:2}Time's up! The menu jumped here automatically."
            },
            {
                "text": "{jump:Untimed_Question}{sectionEnd}"
            }
        ],
        "Untimed_Question": [
            {
                "name": "Phoenix",
                "text": "{showTextbox}{sprite:Phoenix[\"Normal\"]}{blip:1}Now here's a normal option menu with no timer bar."
            },
            {
                "text": "{option:UntimedChoice}{sectionEnd}"
            }
        ],
        "End": [
            {
                "name": "Phoenix",
                "text": "{showTextbox}{sprite:Phoenix[\"Confident\"]}{blip:1}Test complete. Reload the scene if you want to try it again."
            },
            {
                "text": "{sectionEnd}"
            }
        ]
    }
}